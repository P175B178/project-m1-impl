{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Remote ARM Debug",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/pi-debug/warden",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "externalConsole": false,
      "MIMode": "gdb",
      // gdb-multiarch is installed in the devcontainer
      "miDebuggerPath": "/usr/bin/gdb-multiarch",
      "miDebuggerServerAddress": "${env:PI_HOST}:2345",
      "targetArchitecture": "arm64",
      "preLaunchTask": "Pi: Start gdbserver",  // see tasks.json
      "setupCommands": [
        {
          "description": "Enable pretty-printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "Local Debug",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/warden",
      "args": ["--config", "${workspaceFolder}/config/config.cfg"],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
