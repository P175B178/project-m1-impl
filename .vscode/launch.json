// Debug configuration — press F5 to build and debug.
// Requires the C/C++ extension (ms-vscode.cpptools).
{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/warden",
      "args": ["--config", "${workspaceFolder}/config/config.cfg"],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Build",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb"
    }
  ]
}
