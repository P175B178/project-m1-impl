{
  "version": "2.0.0",
  "tasks": [
    // ── ARM: cross-compile ───────────────────────────────────────────────────
    {
      "label": "ARM: Build",
      "type": "shell",
      "command": "cmake --preset arm-debug && cmake --build --preset arm-debug",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "ARM: Build (Release)",
      "type": "shell",
      "command": "cmake --preset arm-release && cmake --build --preset arm-release",
      "group": "build",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "ARM: Deploy",
      "type": "shell",
      "command": "tools/deploy.sh",
      "problemMatcher": []
    },
    {
      "label": "ARM: Run",
      "type": "shell",
      "command": "tools/run.sh",
      "dependsOn": ["ARM: Build", "ARM: Deploy"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    // ── Pi: physical device only ─────────────────────────────────────────────
    {
      // Internal — launched automatically by F5 via launch.json preLaunchTask
      "label": "Pi: Start gdbserver",
      "type": "shell",
      "command": "tools/pi/debug.sh",
      "isBackground": true,
      "problemMatcher": {
        "owner": "arm-debug-server",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "==> Checking if debug port",
          "endsPattern": "Leave this terminal open\\."
        }
      }
    },
    {
      "label": "Pi: SSH",
      "type": "shell",
      "command": "tools/connect.sh",
      "problemMatcher": []
    },
    // ── Pi: setup (one-time) ─────────────────────────────────────────────────
    {
      "label": "Pi: Setup SSH key",
      "type": "shell",
      "command": "tools/setup-ssh.sh",
      "problemMatcher": []
    },
    {
      "label": "Pi: Bootstrap",
      "type": "shell",
      "command": "tools/pi/bootstrap.sh",
      "problemMatcher": []
    },
    // ── Local: host build and tests ──────────────────────────────────────────
    {
      "label": "Local: Build",
      "type": "shell",
      "command": "cmake --preset debug && cmake --build --preset debug",
      "group": "build",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Local: Run tests",
      "type": "shell",
      "command": "ctest --preset debug",
      "dependsOn": "Local: Build",
      "problemMatcher": []
    },
    // ── Workflows ────────────────────────────────────────────────────────────
    {
      "label": "Workflow: Verify",
      "type": "shell",
      "command": "cmake --workflow --preset build-and-test && cmake --workflow --preset tidy",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Workflow: Build and test",
      "type": "shell",
      "command": "cmake --workflow --preset build-and-test",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Workflow: Tidy",
      "type": "shell",
      "command": "cmake --workflow --preset tidy",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Workflow: Package",
      "type": "shell",
      "command": "cmake --workflow --preset package",
      "problemMatcher": ["$gcc"]
    },
    // ── Utilities ────────────────────────────────────────────────────────────
    {
      "label": "Format all sources",
      "type": "shell",
      "command": "cmake --preset arm-debug && cmake --build --preset arm-debug --target format",
      "problemMatcher": []
    },
    {
      "label": "Clean all build directories",
      "type": "shell",
      "command": "rm -rf build",
      "problemMatcher": []
    }
  ]
}
