// VS Code tasks — run via Terminal > Run Task, or use shortcuts:
//   Ctrl+Shift+B  → Local: Build (default build task)
{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Local: Build",
      "type": "shell",
      "command": "cmake --preset debug && cmake --build --preset debug",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Local: Run (sim)",
      "type": "shell",
      "command": "./build/debug/warden -c config/config.cfg",
      "dependsOn": "Local: Build",
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "Local: Run tests",
      "type": "shell",
      "command": "ctest --preset debug",
      "dependsOn": "Local: Build",
      "problemMatcher": []
    },
    // ── Pi ──
    {
      "label": "Pi: Build",
      "type": "shell",
      "command": "cmake --preset pi-debug && cmake --build --preset pi-debug",
      "group": "build",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Pi: Build (Release)",
      "type": "shell",
      "command": "cmake --preset pi-release && cmake --build --preset pi-release",
      "group": "build",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Pi: Deploy",
      "type": "shell",
      "command": "tools/pi/deploy.sh",
      "problemMatcher": []
    },
    {
      "label": "Pi: Run",
      "type": "shell",
      "command": "tools/pi/run.sh",
      "dependsOn": ["Pi: Build", "Pi: Deploy"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    // ── Pi: debug ──
    {
      "label": "Pi: Start gdbserver",
      "type": "shell",
      "command": "tools/pi/debug.sh",
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^==> Starting gdbserver",
          "endsPattern": "^==> Debug server ready"
        }
      }
    },
    {
      "label": "Pi: SSH",
      "type": "shell",
      "command": "tools/pi/connect.sh",
      "problemMatcher": []
    },
    // ── Pi: one-time setup ──
    {
      "label": "Pi init: 1. SSH key",
      "type": "shell",
      "command": "tools/pi/init/01-setup-ssh.sh",
      "problemMatcher": []
    },
    {
      "label": "Pi init: 2. Bootstrap",
      "type": "shell",
      "command": "tools/pi/init/02-bootstrap.sh",
      "problemMatcher": []
    },
    // ── Utilities ──
    {
      "label": "Workflow: Verify",
      "type": "shell",
      "command": "cmake --preset debug && cmake --build --preset debug --target format-check && cmake --workflow --preset tidy && cmake --build --preset debug && ctest --preset debug",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Format all sources",
      "type": "shell",
      "command": "cmake --preset debug && cmake --build --preset debug --target format",
      "problemMatcher": []
    },
    {
      "label": "Clean all build directories",
      "type": "shell",
      "command": "rm -rf build/",
      "problemMatcher": []
    }
  ]
}
