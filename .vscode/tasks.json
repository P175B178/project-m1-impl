{
  "version": "2.0.0",
  "tasks": [
    // ── Local: host build, sim, tests ────────────────────────────────────────
    {
      "label": "Local: Build",
      "type": "shell",
      "command": "cmake --preset debug && cmake --build --preset debug",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Local: Run (sim)",
      "type": "shell",
      "command": "./build/debug/warden -c config/config.cfg",
      "dependsOn": "Local: Build",
      "dependsOrder": "sequence",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Local: Run tests",
      "type": "shell",
      "command": "ctest --preset debug",
      "dependsOn": "Local: Build",
      "problemMatcher": []
    },
    // ── Pi: build and deploy ─────────────────────────────────────────────────
    {
      "label": "Pi: Build",
      "type": "shell",
      "command": "cmake --preset pi-debug && cmake --build --preset pi-debug",
      "group": "build",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Pi: Build (Release)",
      "type": "shell",
      "command": "cmake --preset pi-release && cmake --build --preset pi-release",
      "group": "build",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Pi: Deploy",
      "type": "shell",
      "command": "tools/pi/deploy.sh",
      "problemMatcher": []
    },
    {
      "label": "Pi: Run",
      "type": "shell",
      "command": "tools/pi/run.sh",
      "dependsOn": ["Pi: Build", "Pi: Deploy"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    // ── Pi: debug ────────────────────────────────────────────────────────────
    {
      // Internal — launched automatically by the Pi: Remote Debug launch config
      "label": "Pi: Start gdbserver",
      "type": "shell",
      "command": "tools/pi/debug.sh",
      "isBackground": true,
      "problemMatcher": {
        "owner": "pi-debug-server",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "==> Checking if debug port",
          "endsPattern": "Leave this terminal open\\."
        }
      }
    },
    {
      "label": "Pi: SSH",
      "type": "shell",
      "command": "tools/pi/connect.sh",
      "problemMatcher": []
    },
    // ── Pi init: one-time setup ──────────────────────────────────────────────
    {
      "label": "Pi init: 1. SSH key",
      "type": "shell",
      "command": "tools/pi/init/01-setup-ssh.sh",
      "problemMatcher": []
    },
    {
      "label": "Pi init: 2. Bootstrap",
      "type": "shell",
      "command": "tools/pi/init/02-bootstrap.sh",
      "problemMatcher": []
    },
    // ── Workflows ────────────────────────────────────────────────────────────
    {
      "label": "Workflow: Verify",
      "type": "shell",
      "command": "cmake --preset debug && cmake --build --preset debug --target format && cmake --workflow --preset tidy && cmake --build --preset debug && ctest --preset debug",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Workflow: Package",
      "type": "shell",
      "command": "rm -rf package && cmake --workflow --preset package",
      "problemMatcher": ["$gcc"]
    },
    // ── Utilities ────────────────────────────────────────────────────────────
    {
      "label": "Format all sources",
      "type": "shell",
      "command": "cmake --preset debug && cmake --build --preset debug --target format",
      "problemMatcher": []
    },
    {
      "label": "Clean all build directories",
      "type": "shell",
      "command": "rm -rf build",
      "problemMatcher": []
    }
  ]
}
