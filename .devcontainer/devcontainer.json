// Dev Container configuration — VS Code builds and runs inside this container.
// See https://containers.dev/implementors/json_reference/ for all options.
{
  "name": "Warden",

  // Build the container from the Dockerfile in this directory.
  "build": {
    "dockerfile": "Dockerfile"
  },

  // Additional tools installed on top of the Dockerfile.
  // common-utils adds colored bash prompt and git integration in the terminal.
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false,
      "upgradePackages": false
    }
  },

  // Extensions auto-installed inside the container.
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "twxs.cmake"
      ]
    }
  },

  // Creates .env from the sample if the developer hasn't set one up yet,
  // before the container starts (runs on the local machine).
  "initializeCommand": "sh .devcontainer/init.sh || .devcontainer\\init.bat || exit 0",

  "postCreateCommand": "git config core.hooksPath .githooks",

  // Injects .env into the container environment so VS Code server, terminals,
  // tasks, and launch.json ${env:} variables all see the same values.
  "runArgs": ["--env-file", "${localWorkspaceFolder}/.env"],

  "mounts": [
    "source=warden-gh,target=/root/.config/gh,type=volume",
    "source=warden-ssh,target=/root/.ssh,type=volume"
  ],

  "remoteUser": "root"
}
