#!/bin/bash
# Runs before every commit. Skip with: git commit --no-verify
set -euo pipefail

echo "pre-commit: checking formatting..."

if ! command -v clang-format &>/dev/null; then
    echo "pre-commit: clang-format not found, skipping format check"
    exit 0
fi

if ! find include src \( -name '*.cpp' -o -name '*.hpp' \) \
     | xargs clang-format --dry-run --Werror 2>&1; then
    echo ""
    echo "Formatting errors found. Run the 'Format all sources' task"
    echo "or: cmake --preset arm-debug && cmake --build --preset arm-debug --target format"
    exit 1
fi

echo "pre-commit: OK"
