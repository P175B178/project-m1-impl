{
  "version": 6,
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug / Sim (host)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_HARDWARE": "OFF",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "pi-debug",
      "displayName": "Pi Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/pi-debug",
      "toolchainFile": "${sourceDir}/cmake/toolchains/raspberrypi-aarch64.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_HARDWARE": "ON",
        "BUILD_TESTING": "OFF"
      }
    },
    {
      "name": "pi-release",
      "displayName": "Pi Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/pi-release",
      "toolchainFile": "${sourceDir}/cmake/toolchains/raspberrypi-aarch64.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_HARDWARE": "ON",
        "BUILD_TESTING": "OFF"
      }
    },
    {
      "name": "clang-tidy",
      "displayName": "Clang-tidy (host)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/clang-tidy",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_HARDWARE": "OFF",
        "BUILD_TESTING": "ON",
        "ENABLE_CLANG_TIDY": "ON",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    }
  ],
  "buildPresets": [
    { "name": "debug",       "configurePreset": "debug" },
    { "name": "pi-debug",    "configurePreset": "pi-debug" },
    { "name": "pi-release",  "configurePreset": "pi-release" },
    { "name": "clang-tidy",  "configurePreset": "clang-tidy", "cleanFirst": true }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": { "outputOnFailure": true }
    }
  ],

  "packagePresets": [
    {
      "name": "pi-release",
      "displayName": "Pi Release",
      "configurePreset": "pi-release",
      "generators": ["TGZ", "DEB"],
      "packageDirectory": "${sourceDir}/package"
    }
  ],

  "workflowPresets": [
    {
      "name": "tidy",
      "displayName": "Tidy — static analysis",
      "steps": [
        { "type": "configure", "name": "clang-tidy" },
        { "type": "build",     "name": "clang-tidy" }
      ]
    },
    {
      "name": "package",
      "displayName": "Package — Pi release (.deb + .tar.gz)",
      "steps": [
        { "type": "configure", "name": "pi-release" },
        { "type": "build",     "name": "pi-release" },
        { "type": "package",   "name": "pi-release" }
      ]
    }
  ]
}
