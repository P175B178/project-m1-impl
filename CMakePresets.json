{
  "version": 6,
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug (host)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_HARDWARE": "OFF",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "clang-tidy",
      "displayName": "Clang-tidy (host)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/clang-tidy",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_HARDWARE": "OFF",
        "BUILD_TESTING": "ON",
        "ENABLE_CLANG_TIDY": "ON",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "release",
      "displayName": "Release (host)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_HARDWARE": "OFF",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "arm-debug",
      "displayName": "Pi Debug (aarch64)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/arm-debug",
      "toolchainFile": "${sourceDir}/cmake/toolchains/raspberrypi-aarch64.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_HARDWARE": "ON",
        "BUILD_TESTING": "OFF"
      }
    },
    {
      "name": "arm-release",
      "displayName": "Pi Release (aarch64)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/arm-release",
      "toolchainFile": "${sourceDir}/cmake/toolchains/raspberrypi-aarch64.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_HARDWARE": "ON",
        "BUILD_TESTING": "OFF"
      }
    }
  ],
  "buildPresets": [
    { "name": "debug",       "configurePreset": "debug" },
    { "name": "clang-tidy",  "configurePreset": "clang-tidy" },
    { "name": "release",     "configurePreset": "release" },
    { "name": "arm-debug",    "configurePreset": "arm-debug" },
    { "name": "arm-release",  "configurePreset": "arm-release" }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "release",
      "configurePreset": "release",
      "output": { "outputOnFailure": true }
    }
  ],

  "packagePresets": [
    {
      "name": "arm-release",
      "displayName": "Pi Release (TGZ + DEB)",
      "configurePreset": "arm-release",
      "generators": ["TGZ", "DEB"],
      "packageDirectory": "${sourceDir}/package"
    }
  ],

  "workflowPresets": [
    {
      "name": "build-and-test",
      "displayName": "Build and test",
      "steps": [
        { "type": "configure", "name": "debug" },
        { "type": "build",     "name": "debug" },
        { "type": "test",      "name": "debug" }
      ]
    },
    {
      "name": "tidy",
      "displayName": "Tidy — clang-tidy check",
      "steps": [
        { "type": "configure", "name": "clang-tidy" },
        { "type": "build",     "name": "clang-tidy" }
      ]
    },
    {
      "name": "package",
      "displayName": "Package — Pi release (.deb + .tar.gz)",
      "steps": [
        { "type": "configure", "name": "arm-release" },
        { "type": "build",     "name": "arm-release" },
        { "type": "package",   "name": "arm-release" }
      ]
    }
  ]
}
