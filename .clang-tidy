Checks: >
  clang-diagnostic-*,
  clang-analyzer-*,
  cppcoreguidelines-*,
  modernize-*,
  readability-*,
  performance-*,
  bugprone-*,
  -modernize-use-trailing-return-type,
  -readability-identifier-length,
  -cppcoreguidelines-avoid-magic-numbers,
  -readability-magic-numbers,
  -bugprone-easily-swappable-parameters,
  -cppcoreguidelines-special-member-functions

WarningsAsErrors: ""
CheckOptions:
  # Classes use UpperCamelCase:  StateMachine, WardenApp, AveragingBuffer
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
  # Functions and variables use lowerCamelCase:  currentState(), avgTemp
  # Note: clang-tidy calls this 'camelBack', not 'camelCase' (which is not a valid value)
  - key: readability-identifier-naming.FunctionCase
    value: camelBack
  - key: readability-identifier-naming.VariableCase
    value: camelBack
